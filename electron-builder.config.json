{
  "appId": "com.company.app-name",
  "productName": "Planos Perú",
  "copyright": "Copyright © year ${author}",
  "files": ["main/**/*", "build/**/*"],
  "extraFiles": {
    "from": "backend/dist/",
    "to": "lib/",
    "filter": ["**/**"]
  },

  "directories": {
    "output": "dist"
  },
  "publish": {
    "provider": "github",
    "owner": "Planos-Peru-Ingenieros",
    "repo": "planos-react-app",
    "releaseType": "release"
  },
  "win": {
    "target": "nsis",
    "icon": "public/favicon.ico"
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false
  }
}
