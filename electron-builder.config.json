{
  "appId": "com.company.app-name",
  "productName": "My Awesome App",
  "copyright": "Copyright © year ${author}",
  "files": ["main/**/*", "build/**/*"],
  "extraFiles": {
    "from": "backend/dist/",
    "to": "lib/",
    "filter": ["**/**"]
  },

  "directories": {
    "output": "dist"
  },
  "win": {
    "target": "nsis",
    "icon": "public/assets/media/icon/app.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
