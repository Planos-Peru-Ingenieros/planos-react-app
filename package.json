{
  "name": "planos-peru",
  "version": "1.0.36",
  "description": "Planos Perú",
  "homepage": ".",
  "bugs": {
    "url": "https://github.com/Planos-Peru-Ingenieros/planos-react-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Planos-Peru-Ingenieros/planos-react-app"
  },
  "license": "MIT",
  "author": "The CoreUI Team (https://github.com/orgs/coreui/people)",
  "main": "main/main.js",
  "scripts": {
    "build": "vite build",
    "lint": "eslint",
    "serve": "vite preview",
    "start": "vite",
    "py-install": "pip install -r requirements.txt",
    "py-build": "python -m PyInstaller --workpath=backend/build --distpath=backend/dist api.spec",
    "electron-dev": "electron .",
    "electron-build": "electron-builder --config electron-builder.config.json",
    "release": "electron-builder --config electron-builder.config.json --win"
  },
  "dependencies": {
    "@coreui/chartjs": "^4.1.0",
    "@coreui/coreui": "^5.4.3",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-react": "^2.3.0",
    "@coreui/react": "^5.9.1",
    "@coreui/react-chartjs": "^3.0.0",
    "@coreui/utils": "^2.0.2",
    "@popperjs/core": "^2.11.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "core-js": "^3.46.0",
    "electron-is-dev": "^1.2.0",
    "electron-updater": "^6.6.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.5",
    "react-select": "^5.10.2",
    "react-to-print": "^3.2.0",
    "redux": "5.0.1",
    "simplebar-react": "^3.3.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.13.6",
    "electron": "^13.1.2",
    "electron-builder": "^22.11.7",
    "electron-reloader": "^1.2.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "python-shell": "^3.0.0",
    "sass": "^1.93.2",
    "vite": "^7.1.12"
